{
  "name": "focus-planner-desktop",
  "productName": "Focus Planner",
  "version": "1.1.2",
  "description": "Focus Planner — a Windows desktop window for your daily time-blocking planner.",
  "author": "Focus Planner",
  "license": "MIT",
  "repository": "https://github.com/meilechb/focus-planner",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "app.focusplanner.desktop",
    "productName": "Focus Planner",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "publish": null,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "build/icon.png"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
