# Copy to .env.local for `vercel dev`, or set these in Vercel → Project Settings → Environment Variables.
# There are NO VITE_ public vars — the browser only ever talks to our own /api.

# What the owner types on the login screen.
APP_PASSPHRASE=

# Long random string. Signs the session cookie AND the OAuth state param,
# and derives the AES key used to encrypt refresh tokens at rest.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Auto-set by Vercel when a Blob store is connected. Do not set by hand in prod.
BLOB_READ_WRITE_TOKEN=

# Phase 4 — Google "Web application" OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Phase 5 — Zoho "Server-based Application" client.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
